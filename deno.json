{
  "tasks": {
    "start": "deno run -A -r --env --config=deno.json oxian-js --deno-config=./deno.json",
    "dev": "ENV=dev deno run -A -r --env --config=deno.json oxian-js dev --deno-config=./deno.json",
    "run:agent": "ENV=dev deno run --env -A index.ts",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build"
  },
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals",
    "raw-imports"
  ],
  "imports": {
    "@/": "./",
    "copilotz": "jsr:@copilotz/copilotz@0.34.1",
    "copilotz/server": "jsr:@copilotz/copilotz@0.34.1/server/",
    "oxian-js": "jsr:@oxian/oxian-js@^0.13.0",
    "oxian-js/types": "jsr:@oxian/oxian-js@^0.13.0/types"
  }
}
