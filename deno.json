{
  "name": "@my-scope/my-project",
  "description": "My Copilotz Project",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./api/index.ts"
  },
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals",
    "raw-imports"
  ],
  "tasks": {
    "start": "deno run -A -r --env --config=deno.json oxian-js",
    "dev": "ENV=dev deno run -A -r --env --config=deno.json oxian-js dev",
    "run:agent": "ENV=dev deno run --env -A api/runAgent.ts",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build"
  },
  "imports": {
    "copilotz": "jsr:@copilotz/copilotz@0.25.3",
    "copilotz/server": "jsr:@copilotz/copilotz@0.25.3/server",
    "oxian-js": "jsr:@oxian/oxian-js@^0.12.24",
    "@/": "./"
  }
}
