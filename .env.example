PORT=8000
USE_CACHE=true

# Database URL
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
DATABASE_URL=file:///tmp/copilotz/data.db
# DATABASE_URL=:memory:

# Copilotz UI API Key
API_KEY=

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# LLM_REASONING_EFFORT=medium
LLM_API_KEY=
# LLM_MAX_TOKENS=100000

# Model API Keys (alternative to LLM_API_KEY above)
# OPENAI_KEY=sk-...
# GEMINI_KEY=
# MINIMAX_KEY=

# Serper API Key (for web search tool)
# SERPER_KEY=

# WhatsApp Cloud API
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_ID=

# Zendesk Sunshine Conversations (Smooch)
# ZENDESK_APP_ID=
# ZENDESK_API_KEY=
# ZENDESK_API_SECRET=
# ZENDESK_WEBHOOK_SECRET=
# ZENDESK_BUSINESS_NAME=
# ZENDESK_BUSINESS_LOGO=

# Debugging
# OXIAN_DEBUG=1
# COPILOTZ_DEBUG=1
ENV=DEV
# COPILOTZ_DEBUG_GEMINI_STREAM=1

# Authentication (Google OAuth)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_ALLOWED_ORIGINS=http://localhost:8000
# AUTH_JWT_SECRET=
# AUTH_ENCRYPTION_KEY=
